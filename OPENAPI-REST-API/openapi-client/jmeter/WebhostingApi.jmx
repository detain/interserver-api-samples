          <stringProp name="HTTPSampler.embedded_url_re"></stringProp>
          <stringProp name="TestPlan.comments">Cancel Website Cancels a webhosting service. The service will be scheduled for termination and all hosted content will be removed. This action cannot be undone.</stringProp>
