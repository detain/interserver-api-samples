}


### Submit Login Information
## Submit Login Information
POST https://my.interserver.net/apiv2/login
Content-Type: multipart/form-data
Content-Type: application/json
Accept: application/json
Cookie: sessionid={{cookieKey}}
X-API-KEY: {{apiKey}}
sessionid: {{apiKey}}

### Submit Signup Information
## Submit Signup Information
POST https://my.interserver.net/apiv2/signup
Content-Type: application/json
Accept: application/json
Cookie: sessionid={{cookieKey}}
X-API-KEY: {{apiKey}}
sessionid: {{apiKey}}

{
  "login" : "user@domain.com",
  "passwd" : "mypassword",
  "remember" : "true",
  "g-recaptcha-response" : {
    "__v_isShallow" : false,
    "dep" : {
      "w" : 0,
      "n" : 0
    },
    "__v_isRef" : true,
    "_rawValue" : "zzzzz",
    "_value" : "zzzzz"
  }
}

